<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="BigTextViewThin">
        <item name="android:textColor">#4b4f60</item>
        <item name="android:textSize">35sp</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MediumTextViewThin">
        <item name="android:textColor">#4b4f60</item>
        <item name="android:textSize">25sp</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SmallTextViewThin">
        <item name="android:textColor">@color/g_hint</item>
        <item name="android:textSize">15sp</item>
        <item name="fontFamily">@font/inter_medium</item>
    </style>


    <style name="EditTextSettings">
        <item name="android:width">0dp</item>
        <item name="height">45dp</item>
        <item name="background">@drawable/btn_white_background</item>
        <item name="fontFamily">@font/inter_medium</item>
        <item name="android:gravity">start</item>
        <item name="android:textStyle">bold</item>
        <item name="singleLine">true</item>
        <item name="paddingStart">10dp</item>
    </style>

    <style name="DialogStyle" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

</resources>